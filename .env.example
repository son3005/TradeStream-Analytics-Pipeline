# ==========================================
# TRADE STREAM ANALYTICS PIPELINE - SECRETS
# ==========================================
# Copy file này thành .env rồi điền giá trị thực:
#   cp .env.example .env
# ==========================================

# ==========================
# KAFKA CONFIGURATION
# ==========================
KAFKA_BROKER_URL=localhost:9092

# ==========================
# BINANCE WEBSOCKET API (CRYPTO)
# ==========================
BINANCE_WSS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# ==========================
# YAHOO FINANCE REST API (STOCK)
# ==========================
YAHOO_FINANCE_URL=https://query1.finance.yahoo.com/v8/finance/chart

# ==========================
# TIMESCALEDB (Crypto Data Storage)
# ==========================
TIMESCALE_PASSWORD=CHANGE_ME
TIMESCALE_CONN=host=timescaledb port=5432 dbname=tradestream user=postgres password=CHANGE_ME

# ==========================
# GRAFANA (Dashboard)
# ==========================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ==========================
# AIRFLOW METADATA DATABASE
# ==========================
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGE_ME
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_CONN=postgresql+psycopg2://airflow:CHANGE_ME@airflow-metadata:5432/airflow

# ==========================
# AIRFLOW AUTHENTICATION & SECURITY
# ==========================
AIRFLOW_JWT_SECRET=CHANGE_ME_USE_RANDOM_STRING
AIRFLOW_SECRET_KEY=CHANGE_ME_USE_RANDOM_STRING
AIRFLOW_ADMIN_USERS=admin:CHANGE_ME:Admin

# ==========================
# MINIO (Lakehouse Storage)
# ==========================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_LAKEHOUSE_BUCKET=lakehouse

